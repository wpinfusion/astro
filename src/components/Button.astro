---
import type { HTMLAttributes } from "astro/types";
import { tv, type VariantProps } from "tailwind-variants";

interface Props extends HTMLAttributes<"button">, Omit<HTMLAttributes<"a">, "type">, VariantProps<typeof button> {}

const { variant, size, class: className, ...rest } = Astro.props;

const button = tv({
	base: [
		"inline-flex items-center justify-center gap-1.5 font-semibold whitespace-nowrap transition",
		"[&_svg]:pointer-events-none [&_svg]:shrink-0",
		"focus-visible:outline-2 focus-visible:outline-offset-2",
		"disabled:pointer-events-none",
	],
	variants: {
		variant: {
			default: "bg-gray-800 text-white hover:bg-gray-800/90 focus-visible:outline-gray-800",
			white: "bg-white text-gray-800 hover:bg-gray-100 focus-visible:outline-white",
			ghost: "bg-transparent text-gray-800 hover:bg-gray-100 focus-visible:outline-gray-100",
		},
		size: {
			sm: "h-9 px-3 py-2 text-sm [&_svg]:size-4",
			md: "h-11 px-4 py-2 text-base [&_svg]:size-4",
			lg: "h-12 px-8 py-2 text-lg [&_svg]:size-5",
			icon: "size-11 [&_svg]:size-4",
		},
	},
	defaultVariants: { variant: "default", size: "md" },
});

const Tag = Astro.props.href ? "a" : "button";
---

<Tag class={button({ variant, size, class: className })} {...rest}>
	<slot />
</Tag>
